{
  "name": "open-app-button-component",
  "version": "0.0.2",
  "description": "Zion mini program code component: configurable button for launching the source App.",
  "license": "MIT",
  "homepage": "https://github.com/JiahaoTang-Alvin/zion-wechat-open-app-button",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JiahaoTang-Alvin/zion-wechat-open-app-button.git"
  },
  "category": "input",
  "platforms": [
    "WECHAT"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "watch:build": "npm-watch build"
  },
  "watch": {
    "build": {
      "patterns": [
        "src"
      ],
      "extensions": [
        "ts",
        "tsx"
      ]
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zvm-code-context": "^0.6.8"
  },
  "overrides": {
    "immutable": "5.1.4"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.3.6",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "graphql": "^16.9.0",
    "npm-watch": "^0.13.0",
    "sass": "^1.90.0",
    "typescript": "5.9.2",
    "undici": "^6.25.0",
    "vite": "^5.4.8",
    "vite-plugin-graphql-loader": "^4.0.4",
    "vite-tsconfig-paths": "^5.0.1"
  }
}
